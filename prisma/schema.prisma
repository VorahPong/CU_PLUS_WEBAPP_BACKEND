generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  firstName     String
  lastName      String
  name          String?
  schoolId      String         @unique
  year          String
  role          String         @default("student")
  isActive      Boolean @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  announcements Announcement[] @relation("AnnouncementAuthor")
  sessions Session[]

  createdForms           FormTemplate[]   @relation("CreatedForms")
  createdFolders CourseFolder[]
  studentSubmissions     FormSubmission[] @relation("StudentFormSubmissions")
  reviewedSubmissions    FormSubmission[] @relation("ReviewedFormSubmissions")
  notifications          Notification[]
}

model Announcement {
  id          String   @id @default(uuid())
  message     String
  everyone    Boolean  @default(false)
  firstYear   Boolean  @default(false)
  secondYear  Boolean  @default(false)
  thirdYear   Boolean  @default(false)
  fourthYear  Boolean  @default(false)

  authorId    String
  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FormTemplate {
  id            String           @id @default(uuid())
  title         String
  description   String?
  year          String?          // optional targeting like "1", "2", etc.
  isActive      Boolean          @default(true)
  createdById   String
  folderId      String?
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  dueDate       DateTime?
  instructions  String?

  createdBy     User             @relation("CreatedForms", fields: [createdById], references: [id])
  folder        CourseFolder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  fields        FormField[]
  submissions   FormSubmission[]

  @@index([folderId])
}

model FormField {
  id             String       @id @default(uuid())
  formTemplateId String
  label          String
  type           FieldType
  required       Boolean      @default(false)
  placeholder    String?
  helpText       String?
  sortOrder      Int
  configJson     Json?
  createdAt      DateTime     @default(now())

  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
  answers        FormAnswer[]
}

enum FieldType {
  text
  textarea
  date
  checkbox
  signature
  year
}

model FormSubmission {
  id             String            @id @default(uuid())
  formTemplateId String
  studentId      String
  status         SubmissionStatus  @default(draft)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewedById   String?
  grade          String?
  score          Float?
  feedback       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  attemptNumber Int @default(1)

  formTemplate   FormTemplate      @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
  student        User              @relation("StudentFormSubmissions", fields: [studentId], references: [id])
  reviewedBy     User?             @relation("ReviewedFormSubmissions", fields: [reviewedById], references: [id])
  answers        FormAnswer[]

  @@unique([formTemplateId, studentId])
}

enum SubmissionStatus {
  draft
  submitted
  under_review
  graded
  returned
}

model FormAnswer {
  id               String         @id @default(uuid())
  submissionId     String
  formFieldId      String
  valueText        String?
  valueBoolean     Boolean?
  valueDate        DateTime?
  valueSignatureUrl String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  submission       FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  formField        FormField      @relation(fields: [formFieldId], references: [id], onDelete: Cascade)

  @@unique([submissionId, formFieldId])
}

model CourseFolder {
  id          String         @id @default(uuid())
  title       String
  parentId    String?
  createdById String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  parent      CourseFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    CourseFolder[] @relation("FolderChildren")
  forms       FormTemplate[]

  createdBy   User?          @relation(fields: [createdById], references: [id])

  @@index([parentId])
}

enum NotificationType {
  announcement
  form
}

enum NotificationTargetType {
  announcement
  form
}

model Notification {
  id          String                 @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  targetType  NotificationTargetType
  targetId    String
  isRead      Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([targetType, targetId])
}